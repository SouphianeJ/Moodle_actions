# MongoDB Connection
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/moodle_actions?retryWrites=true&w=majority"
MONGODB_DBNAME="moodle_actions"

# Moodle Configuration
MOODLE_BASE_URL="https://your-moodle.example.com"
MOODLE_WS_TOKEN="your_moodle_webservice_token"

# Hyperplanning SOAP Configuration
SOAP_WSDL_URL="https://monetablissement.hyperplanning.fr/hp2025/services/HpSvcWS?wsdl"
SOAP_USERNAME="ORGANISME\\api@hyperplanning.fr"
SOAP_PASSWORD="your_hyperplanning_password"

# Authentication
AUTH_ALLOWED_EMAILS="admin@example.com,user@example.com"
JWT_SECRET="your_very_long_random_secret_key_at_least_32_characters"

# SMTP Configuration (Gmail/Google Workspace)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your_google_app_password"
SMTP_FROM="Moodle Actions <your-email@gmail.com>"

# Shared agent runtime / exam builder
CODEX_BRIDGE_URL="https://your-runtime.example.com"
AGENT_RUNTIME_APP_ID="moodle-actions"
PROXY_KEY_ID_ACTIVE="codex-v1"
PROXY_SIGNING_KEY_ACTIVE="replace_me"
MOODLE_EXAM_MCP_PROXY_URL="https://mcp-moodle-client-proxy.vercel.app/mcp"
